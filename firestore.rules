rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isValidMutualFund(data) {
      return data.amc is string && data.amc.size() > 0 && data.amc.size() < 100 &&
             data.scheme is string && data.scheme.size() > 0 && data.scheme.size() < 200 &&
             data.units is number && data.units >= 0 &&
             data.avgNav is number && data.avgNav >= 0 &&
             data.uid == request.auth.uid &&
             (!('transactions' in data) || data.transactions is list);
    }
    
    function isValidFixedDeposit(data) {
      return data.bankName is string && data.bankName.size() > 0 && data.bankName.size() < 100 &&
             data.principal is number && data.principal > 0 &&
             data.interestRate is number && data.interestRate >= 0 &&
             data.uid == request.auth.uid;
    }

    function isValidStock(data) {
      return data.symbol is string && data.symbol.size() > 0 && data.symbol.size() < 20 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.quantity is number && data.quantity >= 0 &&
             data.avgPrice is number && data.avgPrice >= 0 &&
             data.uid == request.auth.uid &&
             (!('transactions' in data) || data.transactions is list);
    }

    match /mutual_funds/{mfId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidMutualFund(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.uid) && isValidMutualFund(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }
    
    match /fixed_deposits/{fdId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidFixedDeposit(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.uid) && isValidFixedDeposit(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }
    
    match /stocks/{stockId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidStock(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.uid) && isValidStock(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.uid);
    }

    match /user_settings/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
